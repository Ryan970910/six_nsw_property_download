PGHOST="your_postgres_host"
PGPORT=5432
PGDATABASE="your_database"
PGUSER="your_user"
PGPASSWORD_KEYRING_SERVICE="your_keyring_service"
# Preferred: keep the database password in Windows Credential Manager.
# This project defaults to the service name below.

# Optional. If omitted, PGUSER is used as the credential username.
# PGPASSWORD_KEYRING_USERNAME="your_keyring_username"

# Optional fallback if you do not want to use Windows Credential Manager.
# PGPASSWORD="your_password"

# Optional DSN alternative. If PGDSN is set, it is used instead of the individual fields above.
# PGDSN=postgresql://your_user:your_password@localhost:5432/your_database
